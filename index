<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Instagram Carousel Builder</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>

<style>
    *{
        box-sizing:border-box;
        margin:0;
        padding:0;
        font-family:Arial, sans-serif;
    }

    body{
        background:#111;
        color:white;
        display:flex;
        height:100vh;
        overflow:hidden;
    }

    .sidebar{
        width:360px;
        background:#1b1b1b;
        padding:20px;
        overflow:auto;
        border-right:1px solid #333;
    }

    .sidebar h2{
        margin-bottom:15px;
    }

    .group{
        margin-bottom:24px;
    }

    .group label{
        display:block;
        margin-bottom:8px;
        font-size:14px;
        opacity:0.8;
    }

    .group input,
    .group select,
    .group textarea,
    .group button{
        width:100%;
        margin-bottom:10px;
        padding:10px;
        border:none;
        border-radius:10px;
        background:#2b2b2b;
        color:white;
    }

    button{
        cursor:pointer;
        transition:.2s;
    }

    button:hover{
        background:#444;
    }

    .workspace{
        flex:1;
        display:flex;
        flex-direction:column;
        align-items:center;
        overflow:auto;
        padding:20px;
        gap:30px;
    }

    .slide-container{
        position:relative;
    }

    canvas{
        border-radius:20px;
        box-shadow:0 0 30px rgba(0,0,0,.5);
    }

    .slides-bar{
        display:flex;
        gap:10px;
        flex-wrap:wrap;
        margin-bottom:20px;
    }

    .slide-thumb{
        width:70px;
        height:88px;
        background:#333;
        border-radius:10px;
        cursor:pointer;
        border:2px solid transparent;
    }

    .slide-thumb.active{
        border:2px solid white;
    }

</style>
</head>

<body>

<div class="sidebar">

    <h2>Carousel Builder</h2>

    <div class="group">
        <button onclick="addSlide()">➕ Добавить слайд</button>
        <button onclick="exportPNG()">📥 Скачать PNG</button>
    </div>

    <div class="group">
        <label>Загрузить изображение</label>
        <input type="file" id="imageLoader"/>
        <button onclick="addImageAbove()">🖼 Добавить фото поверх</button>
    </div>

    <div class="group">
        <label>Blur изображения</label>
        <input type="range" min="0" max="20" value="0" id="blurRange"/>
    </div>

    <div class="group">
        <label>Тип затемнения</label>
        <select id="overlayType">
            <option value="gradient">Градиент</option>
            <option value="solid">Сплошная заливка</option>
        </select>

        <label>Цвет</label>
        <input type="color" id="overlayColor" value="#000000"/>

        <label>Прозрачность</label>
        <input type="range" min="0" max="1" step="0.01" value="0.5" id="overlayOpacity"/>

        <button onclick="applyOverlay()">Применить</button>
    </div>

    <div class="group">
        <label>Заголовок</label>
        <input type="text" id="titleText"/>

        <label>Текст</label>
        <textarea id="bodyText"></textarea>

        <label>Шрифт</label>
        <select id="fontFamily">
            <option>Arial</option>
            <option>Georgia</option>
            <option>Verdana</option>
            <option>Impact</option>
        </select>

        <label>Цвет текста</label>
        <input type="color" id="textColor" value="#ffffff"/>

        <button onclick="addTexts()">Добавить текст</button>
    </div>

    <div class="group">
        <label>Magic Ivan PNG</label>

        <select id="logoPosition">
            <option value="top">Сверху</option>
            <option value="center">По центру</option>
            <option value="bottom">Снизу</option>
        </select>

        <label>Размер логотипа</label>
        <input type="range" min="50" max="400" value="180" id="logoSize"/>

        <button onclick="addLogo()">Добавить плашку</button>
    </div>

    <div class="group">
        <button onclick="addSwipeHint()">Добавить «Свайпай →»</button>
    </div>

</div>

<div class="workspace">

    <div class="slides-bar" id="slidesBar"></div>

    <div class="slide-container">
        <canvas id="canvas" width="1080" height="1350"></canvas>
    </div>

</div>

<script>

const canvas = new fabric.Canvas('canvas', {
    preserveObjectStacking:true
});

let slides = [];
let currentSlide = 0;

function saveSlide(){
    slides[currentSlide] = JSON.stringify(canvas.toJSON());
}

function loadSlide(index){
    if(slides[currentSlide]){
        saveSlide();
    }

    currentSlide = index;

    canvas.loadFromJSON(slides[index], () => {
        canvas.renderAll();
    });

    updateSlidesUI();
}

function updateSlidesUI(){

    const bar = document.getElementById('slidesBar');
    bar.innerHTML = '';

    slides.forEach((s,i)=>{

        const div = document.createElement('div');
        div.className = 'slide-thumb';

        if(i === currentSlide){
            div.classList.add('active');
        }

        div.innerHTML = i+1;

        div.onclick = ()=>loadSlide(i);

        bar.appendChild(div);
    });
}

function addSlide(){

    saveSlide();

    canvas.clear();

    slides.push(JSON.stringify(canvas.toJSON()));

    currentSlide = slides.length - 1;

    updateSlidesUI();
}

slides.push(JSON.stringify(canvas.toJSON()));
updateSlidesUI();

document.getElementById('imageLoader').addEventListener('change', function(e){

    const reader = new FileReader();

    reader.onload = function(event){

        fabric.Image.fromURL(event.target.result, function(img){

            img.set({
                left:540,
                top:675,
                originX:'center',
                originY:'center',
                scaleX:1,
                scaleY:1
            });

            img.scaleToWidth(1080);

            canvas.add(img);
            canvas.sendToBack(img);

            canvas.renderAll();
        });
    };

    reader.readAsDataURL(e.target.files[0]);
});

function applyOverlay(){

    const type = document.getElementById('overlayType').value;
    const color = document.getElementById('overlayColor').value;
    const opacity = document.getElementById('overlayOpacity').value;

    let overlay;

    if(type === 'solid'){

        overlay = new fabric.Rect({
            width:1080,
            height:1350,
            fill:color,
            opacity:opacity,
            selectable:true
        });

    }else{

        overlay = new fabric.Rect({
            width:1080,
            height:1350,
            fill:new fabric.Gradient({
                type:'linear',
                coords:{
                    x1:0,
                    y1:1350,
                    x2:0,
                    y2:600
                },
                colorStops:[
                    { offset:0, color:color },
                    { offset:1, color:'transparent' }
                ]
            }),
            opacity:opacity
        });
    }

    canvas.add(overlay);
    canvas.renderAll();
}

function addTexts(){

    const title = document.getElementById('titleText').value;
    const body = document.getElementById('bodyText').value;
    const font = document.getElementById('fontFamily').value;
    const color = document.getElementById('textColor').value;

    if(title){

        const t = new fabric.Textbox(title,{
            width:900,
            left:540,
            top:200,
            originX:'center',
            fill:color,
            fontFamily:font,
            fontWeight:'bold',
            fontSize:72,
            textAlign:'center'
        });

        canvas.add(t);
    }

    if(body){

        const b = new fabric.Textbox(body,{
            width:850,
            left:540,
            top:350,
            originX:'center',
            fill:color,
            fontFamily:font,
            fontSize:36,
            textAlign:'center'
        });

        canvas.add(b);
    }

    canvas.renderAll();
}

function addLogo(){

    const size = document.getElementById('logoSize').value;
    const pos = document.getElementById('logoPosition').value;

    let top = 100;

    if(pos === 'center') top = 675;
    if(pos === 'bottom') top = 1180;

    fabric.Image.fromURL('assets/magic-ivan.png', function(img){

        img.set({
            left:540,
            top:top,
            originX:'center',
            originY:'center'
        });

        img.scaleToWidth(size);

        canvas.add(img);

        canvas.renderAll();
    });
}

function addSwipeHint(){

    const txt = new fabric.Text("Свайпай →",{
        left:870,
        top:1260,
        fill:'white',
        fontSize:32,
        fontWeight:'bold'
    });

    canvas.add(txt);

    canvas.renderAll();
}

function addImageAbove(){

    const input = document.getElementById('imageLoader');

    if(!input.files[0]) return;

    const reader = new FileReader();

    reader.onload = function(event){

        fabric.Image.fromURL(event.target.result, function(img){

            img.set({
                left:540,
                top:675,
                originX:'center',
                originY:'center',
                rx:20,
                ry:20
            });

            img.scaleToWidth(700);

            canvas.add(img);

            canvas.renderAll();
        });
    };

    reader.readAsDataURL(input.files[0]);
}

document.getElementById('blurRange').addEventListener('input', function(){

    const value = parseInt(this.value);

    const active = canvas.getActiveObject();

    if(active && active.type === 'image'){

        active.filters = [
            new fabric.Image.filters.Blur({
                blur:value / 100
            })
        ];

        active.applyFilters();

        canvas.renderAll();
    }
});

function exportPNG(){

    saveSlide();

    slides.forEach((slide, index)=>{

        const tempCanvas = new fabric.Canvas(null,{
            width:1080,
            height:1350
        });

        tempCanvas.loadFromJSON(slide, ()=>{

            const dataURL = tempCanvas.toDataURL({
                format:'png',
                quality:1
            });

            const a = document.createElement('a');
            a.href = dataURL;
            a.download = `slide-${index+1}.png`;
            a.click();
        });
    });
}

</script>

</body>
</html>
